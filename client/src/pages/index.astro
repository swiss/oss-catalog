---
import { getRelativeLocaleUrl } from "astro:i18n";

// DO NOT use Astro.request or Astro.preferredLocale here.
// Instead, just generate the static URLs using the safe helpers:
const fallbackUrl = getRelativeLocaleUrl("en", "");

const targetUrls = {
  en: getRelativeLocaleUrl("en", ""),
  de: getRelativeLocaleUrl("de", ""),
  fr: getRelativeLocaleUrl("fr", ""),
  it: getRelativeLocaleUrl("it", ""),
};
---

<html lang="en">
  <head>
    <title>Redirecting...</title>
    <noscript>
      <meta http-equiv="refresh" content={`0;url=${fallbackUrl}`} />
    </noscript>
  </head>
  <body>
    <script is:inline define:vars={{ targetUrls, fallbackUrl }}>
      const userLanguages = navigator.languages || [navigator.language];
      let matchedUrl = null;

      for (const lang of userLanguages) {
        const shortLang = lang.split("-")[0].toLowerCase(); // e.g., 'de-CH' -> 'de'
        if (targetUrls[shortLang]) {
          matchedUrl = targetUrls[shortLang];
          break;
        }
      }

      window.location.replace(matchedUrl || fallbackUrl);
    </script>
  </body>
</html>
