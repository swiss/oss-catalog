---
// src/pages/software/[...id].astro
import { getRelativeLocaleUrl } from 'astro:i18n';
import { hashUrl } from '@/utils/hash';
import type { Software } from '@/types/software';

export async function getStaticPaths() {
  const apiBaseUrl = import.meta.env.API_BASEURL || "http://localhost:3000/v1";
  
  try {
    const response = await fetch(`${apiBaseUrl}/software?page[size]=10000`);
    if (!response.ok) {
      throw new Error(`HTTP ${response.status}`);
    }
    const data = await response.json();
    const softwares: Software[] = data.data || [];
    
    const paths: Array<{ params: { id: string | undefined } }> = softwares.map((software) => ({
      params: { id: hashUrl(software.url) }
    }));
    
    // Also include undefined to support /softwares/ or /softwares
    paths.push({ params: { id: undefined } });
    
    return paths;
  } catch (e) {
    console.error("Error fetching softwares for redirect paths:", e);
    return [{ params: { id: undefined } }];
  }
}

// If the URL is /software/m2kcbm, then id will be "m2kcbm"
// If the URL is just /software/, id will be undefined
const { id } = Astro.params;
const routePath = id ? `softwares/${id}` : '';

// Map the target localized paths dynamically
const targetUrls = {
  en: getRelativeLocaleUrl('en', routePath),
  de: getRelativeLocaleUrl('de', routePath),
  fr: getRelativeLocaleUrl('fr', routePath),
  it: getRelativeLocaleUrl('it', routePath),
};
const fallbackUrl = targetUrls.en;
---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>Redirecting...</title>
  <noscript>
    <meta http-equiv="refresh" content={`0;url=${fallbackUrl}`} />
  </noscript>
</head>
<body>
  <script is:inline define:vars={{ targetUrls, fallbackUrl }}>
    const userLanguages = navigator.languages || [navigator.language];
    let matchedUrl = null;

    for (const lang of userLanguages) {
      const shortLang = lang.split('-')[0].toLowerCase();
      if (targetUrls[shortLang]) {
        matchedUrl = targetUrls[shortLang];
        break;
      }
    }

    console.log('Redirecting to:', matchedUrl || fallbackUrl);
    // Instantly forward them to the localized path
    window.location.replace(matchedUrl || fallbackUrl);
  </script>
</body>
</html>